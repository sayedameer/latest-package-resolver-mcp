{
  "name": "@sayedameer/latest-package-resolver-mcp",
  "version": "1.0.2",
  "description": "MCP server for resolving latest compatible npm packages",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["mcp", "npm", "resolver", "dependencies", "llm", "agent"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "latest-package-resolver-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "AGENTS.md",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "vitest": "^1.3.1"
  }
}
